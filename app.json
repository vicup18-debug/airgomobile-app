{
  "expo": {
    "name": "Airgo",
    "slug": "airgo-app",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/icon-mark.png",
    "scheme": "airgo",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/icon-mark.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ng.airgo.app",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "ng.airgo.app",
      "versionCode": 31,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB7i70u3_DN4ksi0V6LILlkCCK-Y7Gq8qo"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-mark.png",
        "backgroundColor": "#FFFFFF",
        "monochromeImage": "./assets/images/icon-mark.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo1.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/images/logo1.png"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#000080",
          "defaultChannel": "airgo-urgent-alerts",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ec7ab55-79ef-4f73-83db-90a09c862a33"
      }
    },
    "runtimeVersion": "1.0.7",
    "updates": {
      "url": "https://u.expo.dev/9ec7ab55-79ef-4f73-83db-90a09c862a33"
    },
    "owner": "viu2"
  }
}
